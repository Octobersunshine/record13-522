f7fa 0%, #e8ecf1 100%);\n      border-radius: 10px;\n      padding: 25px;\n      transition: transform 0.3s;\n    }\n    .card:hover { transform: translateY(-5px); }\n    .card h3 { margin-bottom: 10px; color: #667eea; }\n    .card p { margin-bottom: 0; font-size: 0.95rem; }\n    .product-list { list-style: none; }\n    .product-list li {\n      padding: 20px;\n      border-bottom: 1px solid #eee;\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n    }\n    .product-list li:last-child { border-bottom: none; }\n    .product-name { font-weight: 600; color: #444; }\n    .product-price { color: #764ba2; font-weight: bold; font-size: 1.2rem; }\n    .tag {\n      display: inline-block;\n      padding: 4px 12px;\n      background: #e8ecf1;\n      border-radius: 20px;\n      font-size: 0.85rem;\n      margin: 3px;\n      color: #667eea;\n    }\n    footer {\n      text-align: center;\n      color: rgba(255,255,255,0.9);\n      margin-top: 30px;\n      padding: 20px;\n    }\n    .loading {\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      min-height: 200px;\n      font-size: 1.2rem;\n      color: #999;\n    }\n    .spinner {\n      width: 40px;\n      height: 40px;\n      border: 4px solid #e8ecf1;\n      border-top-color: #667eea;\n      border-radius: 50%;\n      animation: spin 1s linear infinite;\n      margin-right: 15px;\n    }\n    @keyframes spin { to { transform: rotate(360deg); } }\n    .stats {\n      display: grid;\n      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n      gap: 20px;\n      margin-top: 30px;\n    }\n    .stat-box {\n      background: linear-gradient(135deg, #667eea22, #764ba222);\n      border-radius: 10px;\n      padding: 25px;\n      text-align: center;\n    }\n    .stat-number { font-size: 2.5rem; font-weight: bold; color: #667eea; }\n    .stat-label { color: #666; margin-top: 5px; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <header>\n      <nav>\n        <a href=\"#/\" data-route=\"/\" class=\"active\">首页</a>\n        <a href=\"#/about\" data-route=\"/about\">关于我们</a>\n        <a href=\"#/products\" data-route=\"/products\">产品列表</a>\n        <a href=\"#/contact\" data-route=\"/contact\">联系方式</a>\n      </nav>\n    </header>\n\n    <main class=\"content\" id=\"app\">\n        <h1>欢迎来到示例 SPA</h1>\n        <p>这是一个用于测试 <strong>单页面应用预渲染</strong> 功能的示例项目。</p>\n        <p>预渲染（Prerendering）是一种在构建时或运行时将 SPA 页面渲染为静态 HTML 的技术，可以显著提升 SEO 表现和首屏加载速度。</p>\n        <div class=\"stats\">\n          <div class=\"stat-box\">\n            <div class=\"stat-number\">99%</div>\n            <div class=\"stat-label\">SEO 友好度</div>\n          </div>\n          <div class=\"stat-box\">\n            <div class=\"stat-number\">2x</div>\n            <div class=\"stat-label\">首屏速度提升</div>\n          </div>\n          <div class=\"stat-box\">\n            <div class=\"stat-number\">0</div>\n            <div class=\"stat-label\">白屏时间</div>\n          </div>\n        </div>\n        <h2 style=\"margin-top: 40px;\">核心特性</h2>\n        <div class=\"grid\">\n          <div class=\"card\">\n            <h3>🚀 极速渲染</h3>\n            <p>使用 Puppeteer 无头浏览器，支持页面完全加载后再捕获内容。</p>\n          </div>\n          <div class=\"card\">\n            <h3>📦 静态输出</h3>\n            <p>生成纯静态 HTML 文件，可直接部署到 CDN 或静态托管服务。</p>\n          </div>\n          <div class=\"card\">\n            <h3>🔍 SEO 优化</h3>\n            <p>搜索引擎爬虫可直接读取完整内容，无需执行 JavaScript。</p>\n          </div>\n        </div>\n      </main>\n\n    <footer>\n      <p>© 2026 示例 SPA 应用 | 用于预渲染测试</p>\n    </footer>\n  </div>\n\n  <script>\n    const routes = {\n      '/': () => `\n        <h1>欢迎来到示例 SPA</h1>\n        <p>这是一个用于测试 <strong>单页面应用预渲染</strong> 功能的示例项目。</p>\n        <p>预渲染（Prerendering）是一种在构建时或运行时将 SPA 页面渲染为静态 HTML 的技术，可以显著提升 SEO 表现和首屏加载速度。</p>\n        <div class=\"stats\">\n          <div class=\"stat-box\">\n            <div class=\"stat-number\">99%</div>\n            <div class=\"stat-label\">SEO 友好度</div>\n          </div>\n          <div class=\"stat-box\">\n            <div class=\"stat-number\">2x</div>\n            <div class=\"stat-label\">首屏速度提升</div>\n          </div>\n          <div class=\"stat-box\">\n            <div class=\"stat-number\">0</div>\n            <div class=\"stat-label\">白屏时间</div>\n          </div>\n        </div>\n        <h2 style=\"margin-top: 40px;\">核心特性</h2>\n        <div class=\"grid\">\n          <div class=\"card\">\n            <h3>🚀 极速渲染</h3>\n            <p>使用 Puppeteer 无头浏览器，支持页面完全加载后再捕获内容。</p>\n          </div>\n          <div class=\"card\">\n            <h3>📦 静态输出</h3>\n            <p>生成纯静态 HTML 文件，可直接部署到 CDN 或静态托管服务。</p>\n          </div>\n          <div class=\"card\">\n            <h3>🔍 SEO 优化</h3>\n            <p>搜索引擎爬虫可直接读取完整内容，无需执行 JavaScript。</p>\n          </div>\n        </div>\n      `,\n      '/about': () => `\n        <h1>关于我们</h1>\n        <h2>我们的使命</h2>\n        <p>我们致力于为开发者提供最优质的前端工具和服务，帮助团队构建高性能、易维护的 Web 应用。</p>\n        <h2 style=\"margin-top: 30px;\">团队成员</h2>\n        <div class=\"grid\">\n          <div class=\"card\">\n            <h3>👨‍💻 张三</h3>\n            <p>前端架构师，10 年开发经验，专注于性能优化和工程化。</p>\n            <div style=\"margin-top: 15px;\">\n              <span class=\"tag\">Vue</span>\n              <span class=\"tag\">React</span>\n              <span class=\"tag\">性能优化</span>\n            </div>\n          </div>\n          <div class=\"card\">\n            <h3>👩‍💻 李四</h3>\n            <p>全栈工程师，擅长 Node.js 服务端开发和 DevOps。</p>\n            <div style=\"margin-top: 15px;\">\n              <span class=\"tag\">Node.js</span>\n              <span class=\"tag\">Docker</span>\n              <span class=\"tag\">K8s</span>\n            </div>\n          </div>\n          <div class=\"card\">\n            <h3>👨‍🎨 王五</h3>\n            <p>UI/UX 设计师，注重用户体验和视觉美感。</p>\n            <div style=\"margin-top: 15px;\">\n              <span class=\"tag\">Figma</span>\n              <span class=\"tag\">交互设计</span>\n              <span class=\"tag\">动效</span>\n            </div>\n          </div>\n        </div>\n      `,\n      '/products': () => {\n        const products = [\n          { id: 1, name: '企业级管理后台', price: '¥9,999' },\n          { id: 2, name: '电商平台系统', price: '¥19,999' },\n          { id: 3, name: '移动端 App 开发', price: '¥29,999' },\n          { id: 4, name: '数据可视化大屏', price: '¥15,999' },\n          { id: 5, name: '微服务架构咨询', price: '¥5,000/天' },\n          { id: 6, name: 'SEO 优化服务', price: '¥3,999' }\n        ];\n        return `\n          <h1>产品列表</h1>\n          <p>我们提供全方位的软件解决方案，满足不同规模企业的需求。</p>\n          <h2 style=\"margin-top: 30px;\">热门产品</h2>\n          <ul class=\"product-list\">\n            ${products.map(p => `\n              <li>\n                <div>\n                  <div class=\"product-name\">${p.id}. ${p.name}</div>\n                  <div style=\"color: #888; font-size: 0.9rem; margin-top: 5px;\">专业团队 · 快速交付 · 售后保障</div>\n                </div>\n                <div class=\"product-price\">${p.price}</div>\n              </li>\n            `).join('')}\n          </ul>\n        `;\n      },\n      '/contact': () => `\n        <h1>联系我们</h1>\n        <p>如有任何问题或合作意向，欢迎随时与我们取得联系。</p>\n        <div class=\"grid\">\n          <div class=\"card\">\n            <h3>📧 电子邮件</h3>\n            <p>商务合作：business@example.com</p>\n            <p>技术支持：support@example.com</p>\n          </div>\n          <div class=\"card\">\n            <h3>📞 电话</h3>\n            <p>客服热线：400-123-4567</p>\n            <p>工作时间：周一至周五 9:00-18:00</p>\n          </div>\n          <div class=\"card\">\n            <h3>📍 地址</h3>\n            <p>北京市朝阳区科技园区 88 号</p>\n            <p>创新大厦 A 座 2026 室</p>\n          </div>\n        </div>\n        <h2 style=\"margin-top: 40px;\">在线留言</h2>\n        <p>您也可以直接在下方留言，我们会尽快回复您：</p>\n        <div class=\"card\" style=\"margin-top: 20px;\">\n          <p><strong>温馨提示：</strong>这是一个演示页面，表单提交功能暂未开放。</p>\n          <p>请通过上述联系方式与我们